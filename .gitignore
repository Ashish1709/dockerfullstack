# Node dependencies
node_modules/
*/node_modules/

# Build folders
dist/
.next/
*/.next/

# Environment files - do not upload secrets
.env
.env.local
.env.*
backend/.env
frontend/.env.local

# But allow example env files
!.env.example
!backend/.env.example
!frontend/.env.example

# Uploads - keep folder but not uploaded files
backend/uploads/*
!backend/uploads/.gitkeep

# Logs
*.log
npm-debug.log*

# OS/editor files
.DS_Store
.vscode/
.idea/